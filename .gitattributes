# Fins de ligne maîtrisées — pièges réels de ce projet :
# - les *.sh (initdb) tournent DANS le conteneur Linux : CRLF les casserait
#   (déjà vécu au provisioning avec create.sh) -> LF forcé au checkout.
# - les *.ps1 sont des scripts Windows PowerShell 5.1 -> CRLF forcé
#   (leur BOM UTF-8, requis, n'est pas affecté par git).
* text=auto

*.sh    text eol=lf
*.sql   text eol=lf
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.jsonl text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.md    text
*.drawio text

# Fichiers de configuration montés/lus dans les conteneurs Linux -> LF
Dockerfile    text eol=lf
*.conf        text eol=lf
*.txt         text eol=lf
.env.example  text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

*.ps1   text eol=crlf

*.png   binary
*.pdf   binary
*.gguf  binary
