# ============================================================================
# .env.example — Gabarit de configuration NON sensible (SPEC §2.1)
# ----------------------------------------------------------------------------
# Copier ce fichier vers `.env` (fait automatiquement par 01_provision.ps1)
# puis ajuster si besoin. AUCUN secret ici : les valeurs sensibles sont des
# FICHIERS montés en lecture seule sous /run/secrets_rag/ (invariant 2).
# `.env` est ignoré par git ; seul ce gabarit est versionné.
# ============================================================================

# --- PostgreSQL (service docker interne, jamais publié — S1) ---------------
PG_HOST=rag-db
PG_PORT=5432
PG_DATABASE=ragdb

# Rôles (moindre privilège — S2/S3, NOTES §5)
PG_ADMIN_USER=rag_admin
PG_INGEST_USER=rag_ingest
PG_READER_USER=rag_reader
PG_AUDITOR_USER=rag_auditor

# Mots de passe : chemins de FICHIERS (jamais la valeur en clair)
PG_ADMIN_PASSWORD_FILE=/run/secrets_rag/pg_admin_pw
PG_INGEST_PASSWORD_FILE=/run/secrets_rag/pg_ingest_pw
PG_READER_PASSWORD_FILE=/run/secrets_rag/pg_reader_pw
PG_AUDITOR_PASSWORD_FILE=/run/secrets_rag/pg_auditor_pw

# Bootstrap de l'image postgres : le superutilisateur EST rag_admin (SPEC §2.1)
# → 01_roles.sh ne crée que rag_ingest / rag_reader / rag_auditor.
POSTGRES_USER=rag_admin
POSTGRES_PASSWORD_FILE=/run/secrets_rag/pg_admin_pw

# --- Clés applicatives (fichiers, distinctes — invariant 8) ----------------
PGCRYPTO_KEY_FILE=/run/secrets_rag/pgcrypto_key
HMAC_KEY_FILE=/run/secrets_rag/hmac_key

# --- Ollama / modèles (D2, D3) ----------------------------------------------
OLLAMA_URL=http://rag-ollama:11434
LLM_MODEL=llama3.1:8b
# Repli si VRAM < 6 Go (README §Dépannage) : LLM_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
# Identité versionnée écrite dans chunks.embedding_model (D14).
# Valeur indicative : doit refléter le modèle réellement servi
# (README : dériver de `ollama show nomic-embed-text` après le pull).
EMBED_MODEL_TAG=nomic-embed-text@v1.5
EMBED_DIM=768
# Timeout (secondes) des appels HTTP vers Ollama (embeddings + génération)
OLLAMA_TIMEOUT=120

# --- Paramètres RAG (NOTES §4) ----------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
# Seuil de SIMILARITÉ cosinus (∈ [-1,1]) sous lequel aucun contexte n'est
# injecté. Rappel invariant 8 : pgvector `<=>` renvoie une DISTANCE ;
# similarité = 1 - distance (conversion faite dans db.py).
SIM_THRESHOLD=0.35
# Fenêtre de contexte Ollama — ne PAS laisser le défaut 2048 (invariant 12)
NUM_CTX=8192
# Graine fixe : sélection (F1) et génération (F10) — invariant 12
SEED=42

# --- Garde anti-injection (S7) ----------------------------------------------
# Score ∈ [0,1] à partir duquel un document part en quarantaine (SPEC §3.3)
INJECTION_THRESHOLD=0.5

# --- Ingestion ----------------------------------------------------------------
# Fichier JSONL produit par scripts/download_dataset.py (monté RO dans rag-app)
DATASET_FILE=/data/rag_subset.jsonl

# --- Journalisation (F12/S4) --------------------------------------------------
LOG_DIR=/logs

# --- Phase 2 : API (D12) -------------------------------------------------------
API_TOKEN_FILE=/run/secrets_rag/api_token
ADMIN_TOKEN_FILE=/run/secrets_rag/admin_token
