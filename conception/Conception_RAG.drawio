                </mxCell>
                <mxCell id="p5_n3" value="Droits (GRANT) : rag_admin = ALL + DDL (humain) · rag_ingest = INSERT+SELECT sur documents/chunks/ingest_log, INSERT seul sur quarantine (ingest.py) · rag_reader = SELECT seul, jamais sur quarantine (query.py) · rag_auditor (phase 2) = SELECT ingest_log + colonnes métadonnées de quarantine et de documents (pii_stats), jamais content_enc (/admin, D13) — REVOKE ALL sur PUBLIC. Détail : NOTES_conception.md §5" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fontSize=11;align=left;spacing=8;" parent="p5_1" vertex="1">
